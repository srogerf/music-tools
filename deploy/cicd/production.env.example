GHCR_IMAGE_REPO="ghcr.io/srogerf/music-tools/rifferone"
GHCR_USER="srogerf"
GHCR_TOKEN="replace_with_github_pull_token"
GHCR_PUSH_TOKEN="replace_with_github_push_token"

# Default release tag for local shell wrappers. Override with --tag when needed.
IMAGE_TAG="main"

# Extra tags to apply/push during publication, comma-separated.
EXTRA_IMAGE_TAGS="main"

BASTION_ENV_FILE=".private/bastion/music-tools.env"
LOCAL_PRODUCTION_COMPOSE_ENV=".private/deploy/production.compose.env"

REMOTE_USER="opc"
REMOTE_RUNTIME_PATH="/srv/rifferone/app"
REMOTE_COMPOSE_FILE="/srv/rifferone/app/docker-compose.yml"
REMOTE_COMPOSE_ENV_FILE="/srv/rifferone/app/compose.env"
REMOTE_PROXY_URL="http://127.0.0.1:3128"
