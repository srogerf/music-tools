# Application runtime.
# Public local integration HTTP port. nginx listens here and proxies to rifferone:8080.
# Use 8082 locally if dev (:8080) or test artifact (:8081) are already running.
RIFFERONE_HTTP_PORT=8080
NGINX_LOG_PATH=../../../.private/container/local-integration/logs/nginx
GOACCESS_REPORT_PATH=../../../.private/container/local-integration/reports

# Postgres runtime for the local integration environment.
POSTGRES_DB=music_tools
POSTGRES_USER=music_tools
POSTGRES_PASSWORD=replace_with_secure_password
POSTGRES_DATA_PATH=../../../.private/container/local-integration/postgres-data
